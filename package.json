{
  "name": "devsecops-pipeline-demo",
  "version": "1.0.0",
  "description": "Small Express REST API demonstrating a complete DevSecOps CI/CD pipeline: lint, tests, container build, vulnerability scanning, and registry publish",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --coverage",
    "lint": "eslint src tests"
  },
  "keywords": [
    "devsecops",
    "ci-cd",
    "docker",
    "github-actions",
    "trivy"
  ],
  "author": "Wassim Ghiloufi <ghiloufiwassim@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
